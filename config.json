{
  "name": "claw-memory",
  "version": "4.0.0",
  "description": "OpenClaw-UltraMemory V4 - 热度钉扎滑动窗 + 父子链上下文",
  "memory_dir": "~/.workbuddy/memory",
  "db_path": "~/.workbuddy/memory/hot_window.db",
  "raw_dir": "~/.workbuddy/memory/raw",
  "window": {
    "size": 1000,
    "protect_secs": 604800,
    "decay_rate": 0.99,
    "heat_cap": 200,
    "heat_floor": 1
  },
  "search": {
    "top_k": 10,
    "keywords_max": 5
  },
  "auto_skill": {
    "reinforce_threshold": 3,
    "min_content_length": 200,
    "similarity_threshold": 0.8
  }
}
